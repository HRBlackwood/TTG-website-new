rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true;
    }

    // Public website reads upcoming/current events.
    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Public website reads current site content.
    match /siteContent/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Memberships can be created by website visitors.
    // Reads/deletes are admin-only.
    match /memberships/{memberId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Admin allow-list:
    // - signed-in users can read their own admin profile document
    // - only existing admins can edit admin records
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if isAdmin();
    }
  }
}
